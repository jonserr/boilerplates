    %% ========================================================================
    %% ACTIVE CLASS DEFINITIONS
    %% ========================================================================
    %% Apply classes after creating nodes:
    %% class NODE_ID_A,NODE_ID_B blue;

    classDef neutral fill:#f9fafb,stroke:#374151,stroke-width:6px,color:#111111;

    classDef blue fill:#dbeafe,stroke:#2563eb,stroke-width:6px,color:#111111;
    classDef purple fill:#ede9fe,stroke:#7c3aed,stroke-width:6px,color:#111111;
    classDef teal fill:#ccfbf1,stroke:#0f766e,stroke-width:20px,color:#111111;
    classDef pink fill:#fce7f3,stroke:#db2777,stroke-width:6px,color:#111111;
    classDef orange fill:#ffedd5,stroke:#ea580c,stroke-width:6px,color:#111111;
    classDef green fill:#dcfce7,stroke:#16a34a,stroke-width:20px,color:#111111;
    classDef gray fill:#f9fafb,stroke:#9ca3af,stroke-width:20px,color:#111111;

    classDef readPath fill:#dbeafe,stroke:#2563eb,stroke-width:8px,color:#111111;
    classDef writePath fill:#ffedd5,stroke:#ea580c,stroke-width:8px,color:#111111;
    classDef transparent fill:transparent,stroke:transparent,color:#111111;

